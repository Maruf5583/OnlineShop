@using OnlineShop.Models
@model IEnumerable<Products>

@{
    ViewData["Title"] = "Products";
}

<div class="card shadow-sm">
    <div class="card-body">
        @if (TempData["success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h4 class="mb-0 text-primary">Products <small class="text-muted">(@Model?.Count() )</small></h4>
            <div class="d-flex gap-2">
             
                <a asp-action="Create" class="btn btn-sm btn-success"> + Add New Product</a>
            </div>
        </div>
        <form method="post" class="row g-2 mb-4 gap-3">
            <div class="col-3 " >
                <input type="number" class="form-control"
                       name="LowAmount" placeholder="Min Price" />
            </div>

            <div class="col-3">
                <input type="number" class="form-control"
                       name="LargeAmount" placeholder="Max Price" />
            </div>

            <div class="col-1">
                <button type="submit" class="btn btn-primary w-100">
                    Search
                </button>
            </div>
        </form>


       

        <div class="table-responsive">
            <table id="productsTable" class="table table-hover table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Image</th>
                        <th>Type</th>
                        <th>Tag</th>
                        <th>Abalabile</th>
                        <th class="text-end" style="width:240px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                    <tr>
                            <td>@item.Name</td>
                            <td>@item.Price.ToString("C")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item?.Image))
                                {
                                    <img src="~/images/products/@item.Image" alt="thumb" class="img-thumbnail" style="max-width:80px" />
                                }
                            </td>
                            <td>@item.ProductTypes?.ProductType</td>
                            <td>@item.SpecialTag?.TagName</td>
                            <td>@item.IsAvaliable</td>
                            <td class="text-end">
                                <partial name="_ButtonPartial" model="@item.Id" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

