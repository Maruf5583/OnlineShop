@model OnlineShop.Models.Products

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Product</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">Name</dt>
        <dd class = "col-sm-10">@Model.Name</dd>

        <dt class = "col-sm-2">Price</dt>
        <dd class = "col-sm-10">@Model.Price.ToString("C")</dd>

        <dt class = "col-sm-2">Color</dt>
        <dd class = "col-sm-10">@Model.ProductColor</dd>

        <dt class = "col-sm-2">Available</dt>
        <dd class = "col-sm-10">@Model.IsAvaliable</dd>

        <dt class = "col-sm-2">Type</dt>
        <dd class = "col-sm-10">@Model.ProductTypes?.ProductType</dd>

        <dt class = "col-sm-2">Tag</dt>
        <dd class = "col-sm-10">@Model.SpecialTag?.TagName</dd>
    </dl>
    @if (!string.IsNullOrEmpty(Model?.Image))
    {
        <div class="mb-3">
            <img src="~/images/products/@Model.Image" alt="Product image" class="img-fluid img-thumbnail" style="max-width:320px" />
        </div>
    }
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
