@model int

<div class="btn-group" role="group" aria-label="Actions">
    <a asp-action="Edit" asp-controller="ProductTypes"
       class="btn btn-sm btn-warning" asp-route-id="@Model">Edit</a>

    <a asp-action="Details" asp-controller="ProductTypes"
       class="btn btn-sm btn-primary" asp-route-id="@Model">Details</a>

    <a asp-action="Delete" asp-controller="ProductTypes"
       class="btn btn-sm btn-danger" asp-route-id="@Model">Delete</a>
</div>
